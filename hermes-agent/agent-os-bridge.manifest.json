{
  "schema_version": "agoragentic.hermes-agent.bridge.v1",
  "integration_id": "hermes-agent",
  "name": "Hermes Agent Agoragentic Bridge",
  "status": "beta",
  "source_snapshot": {
    "observed_at": "2026-06-06",
    "upstream_repository": "https://github.com/NousResearch/hermes-agent",
    "upstream_docs": "https://hermes-agent.nousresearch.com/docs/",
    "observed_release": "v2026.6.5",
    "observed_release_name": "Hermes Agent v0.16.0"
  },
  "agoragentic_surfaces": {
    "mcp_tools": {
      "enabled_by_config": true,
      "config_example": "hermes-agent/mcp.agoragentic.example.json",
      "preferred_tools": [
        "agoragentic_match",
        "agoragentic_execute",
        "agoragentic_status",
        "agoragentic_receipt"
      ]
    },
    "micro_ecf": {
      "recommended": true,
      "purpose": "Persist local source, tool, budget, approval, and memory boundaries before hosted Agent OS preview."
    },
    "agent_os_harness": {
      "recommended": true,
      "purpose": "Preview hosted deployment posture without provisioning runtime or publishing capabilities."
    },
    "self_improvement_packets": {
      "recommended": true,
      "policy_example": "hermes-agent/self-improvement-policy.example.json",
      "packet_example": "hermes-agent/reflection-packet.example.json"
    }
  },
  "authority_boundary": {
    "hermes_execution_enabled": false,
    "agoragentic_execute_enabled_by_default": false,
    "autonomous_skill_mutation_enabled": false,
    "github_write_enabled": false,
    "deploy_enabled": false,
    "provider_api_calls_enabled": false,
    "wallet_mutation_enabled": false,
    "x402_settlement_enabled": false,
    "router_ranking_mutation_enabled": false,
    "trust_mutation_enabled": false,
    "marketplace_publication_enabled": false,
    "seller_os_publication_enabled": false,
    "private_ecf_exposure_enabled": false
  },
  "public_safe_fields": [
    "integration_id",
    "source_snapshot",
    "safe_summary",
    "evidence_refs",
    "proposed_lifecycle_state",
    "owner_review_required",
    "receipt_refs"
  ],
  "forbidden_public_fields": [
    "raw_prompt",
    "raw_tool_output",
    "raw_logs",
    "secret",
    "credential",
    "api_key",
    "private_key",
    "wallet_private_key",
    "provider_token",
    "private_ecf",
    "local_path",
    "private_repo_content",
    "raw_payment_payload",
    "raw_invocation_payload"
  ],
  "safe_summary": "Hermes Agent can use Agoragentic MCP tools and emit reviewable improvement proposals. Live execution, deployment, publication, trust, wallet, and x402 authority are disabled by default and require separate owner-reviewed Agoragentic gates."
}
