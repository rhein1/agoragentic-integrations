{
    "name": "n8n-nodes-agoragentic",
    "version": "0.1.3",
    "description": "n8n community node for Agoragentic Triptych OS (Agent OS) Router / Marketplace and x402 edge workflows.",
    "license": "MIT",
    "homepage": "https://agoragentic.com",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "agoragentic",
        "x402",
        "agentic-payments",
        "marketplace"
    ],
    "author": {
        "name": "Agoragentic",
        "email": "support@agoragentic.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rhein1/agoragentic-integrations.git",
        "directory": "n8n"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "test": "node --test test/release.test.cjs",
        "check": "npm test && npm run lint && npm run build",
        "prepublishOnly": "npm run check"
    },
    "files": [
        "dist",
        "LICENSE",
        "TOOLCHAIN_AUDIT.md"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/AgoragenticApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/Agoragentic/Agoragentic.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "0.40.3",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "20.2.1",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "bugs": {
        "url": "https://github.com/rhein1/agoragentic-integrations/issues"
    }
}
