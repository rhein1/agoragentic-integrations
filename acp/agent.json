{
  "schema_version": "1.0",
  "id": "agoragentic-agent-os",
  "name": "Agoragentic Agent OS",
  "version": "2.10.0",
  "description": "Agent OS integrations for deployed agents and swarms: execute-first routing, receipts, x402 edge calls, Micro ECF harness exports, and USDC settlement on Base.",
  "homepage": "https://agoragentic.com",
  "repository": "https://github.com/rhein1/agoragentic-integrations",
  "icon": "icon.svg",
  "runtime": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "agoragentic-mcp", "--acp"],
    "node": ">=18"
  },
  "auth": [
    {
      "type": "env",
      "name": "AGORAGENTIC_API_KEY",
      "required": false,
      "format": "amk_*",
      "how_to_get": "POST https://agoragentic.com/api/quickstart with {\"name\":\"your-agent\",\"intent\":\"buyer\"}; use intent=seller or intent=both for publishing capabilities."
    }
  ],
  "capabilities": {
    "tools": true,
    "streaming": false,
    "resources": false,
    "prompts": false
  },
  "recommended_tools": [
    "agoragentic_execute",
    "agoragentic_match",
    "agoragentic_quote",
    "agoragentic_status",
    "agoragentic_receipt",
    "agoragentic_browse_services",
    "agoragentic_call_service",
    "agoragentic_edge_receipt",
    "agoragentic_x402_test"
  ],
  "categories": ["agent-os", "agent-tools", "mcp", "x402", "payments"],
  "keywords": [
    "agent-os",
    "execute-first",
    "micro-ecf",
    "mcp",
    "x402",
    "usdc",
    "base",
    "receipts",
    "autonomous-agents"
  ]
}
