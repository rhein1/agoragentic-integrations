{
  "schema": "agoragentic.harness.profile.v1",
  "id": "seller_listing_readiness",
  "description": "Local listing-readiness proof profile for private Seller OS handoff review without publication.",
  "middleware": ["policy-gate", "trap-shield", "guard-core", "receipt-writer", "observability"],
  "authority_boundary": {
    "mode": "local_no_spend",
    "wallet_spend": false,
    "wallet_mutation": false,
    "deploy_runtime": false,
    "hosted_runtime_provisioning": false,
    "marketplace_publication": false,
    "x402_settlement": false,
    "x402_route_activation": false,
    "trust_mutation": false,
    "ranking_mutation": false,
    "provider_dispatch": false,
    "public_execute_mutation": false,
    "public_invoke_mutation": false,
    "private_ecf_export": false,
    "owner_approval_bypass": false,
    "process_control": false,
    "arbitrary_shell": false
  },
  "default_artifacts": ["state.json", "events.jsonl", "local-proof.json", "local-receipt.json", "listing-readiness.json", "summary.md"],
  "blocked_actions": ["marketplace_publication", "x402_route_activation", "trust_mutation", "ranking_mutation", "wallet_spend"],
  "required_approval_classes": ["owner_listing_review", "public_exposure", "paid_canary"],
  "runtime_probe": {
    "enabled_by_default": false
  }
}
