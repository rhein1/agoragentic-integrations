{
  "schema": "agoragentic.harness.profile.v1",
  "id": "runtime_probe_only",
  "description": "Metadata-only loopback runtime probe profile for local/self-hosted runtime readiness checks.",
  "middleware": ["trap-shield", "observability"],
  "authority_boundary": {
    "mode": "local_no_spend",
    "wallet_spend": false,
    "wallet_mutation": false,
    "deploy_runtime": false,
    "hosted_runtime_provisioning": false,
    "marketplace_publication": false,
    "x402_settlement": false,
    "x402_route_activation": false,
    "trust_mutation": false,
    "ranking_mutation": false,
    "provider_dispatch": false,
    "public_execute_mutation": false,
    "public_invoke_mutation": false,
    "private_ecf_export": false,
    "owner_approval_bypass": false,
    "process_control": false,
    "arbitrary_shell": false
  },
  "default_artifacts": ["state.json", "events.jsonl", "runtime-probe.json", "summary.md"],
  "blocked_actions": ["invoke", "execute", "provider_dispatch", "process_control", "wallet_spend", "x402_settlement"],
  "required_approval_classes": ["remote_runtime_probe_opt_in"],
  "runtime_probe": {
    "enabled_by_default": true,
    "contract": "agoragentic-rust-http"
  }
}
