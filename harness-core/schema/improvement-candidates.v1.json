{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agoragentic.com/schema/harness-core/improvement-candidates.v1.json",
  "title": "Agoragentic Harness Core Improvement Candidates v1",
  "description": "Local Harness Core self-improvement candidate records derived from run evidence only. Candidates are owner-review records and grant no autonomous code mutation, Git/PR creation, hosted memory write, provider dispatch, execute/invoke change, wallet, x402, marketplace, or trust authority.",
  "type": "object",
  "required": ["schema", "created_at", "updated_at", "mode", "candidates", "decisions", "summary", "action_executed", "authority_boundary"],
  "properties": {
    "schema": { "const": "agoragentic.harness.improvement-candidates.v1" },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 },
    "mode": { "const": "local_self_improvement_candidates_no_execution" },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/definitions/candidate" }
    },
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/definitions/decision" }
    },
    "summary": {
      "type": "object",
      "required": ["candidate_count", "open_candidate_count", "decision_count", "action_executed"],
      "properties": {
        "candidate_count": { "type": "integer", "minimum": 0 },
        "open_candidate_count": { "type": "integer", "minimum": 0 },
        "accepted_count": { "type": "integer", "minimum": 0 },
        "rejected_count": { "type": "integer", "minimum": 0 },
        "deferred_count": { "type": "integer", "minimum": 0 },
        "decision_count": { "type": "integer", "minimum": 0 },
        "latest_decision_ref": { "type": ["string", "null"] },
        "action_executed": { "const": false }
      },
      "additionalProperties": true
    },
    "action_executed": { "const": false },
    "authority_boundary": { "$ref": "#/definitions/authority_boundary" }
  },
  "additionalProperties": true,
  "definitions": {
    "candidate": {
      "type": "object",
      "required": ["schema", "candidate_id", "source", "created_at", "updated_at", "status", "title", "evidence_refs", "risk_class", "affected_surface", "suggested_next_action", "action_executed", "authority_boundary"],
      "properties": {
        "schema": { "const": "agoragentic.harness.improvement-candidate.v1" },
        "candidate_id": { "type": "string", "minLength": 1 },
        "source": {
          "type": "object",
          "required": ["kind", "run_id"],
          "properties": {
            "kind": { "const": "harness_run" },
            "run_id": { "type": "string", "minLength": 1 },
            "profile": { "type": ["string", "null"] },
            "status": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "created_at": { "type": "string", "minLength": 1 },
        "updated_at": { "type": "string", "minLength": 1 },
        "status": { "enum": ["open", "accepted", "rejected", "deferred"] },
        "title": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/definitions/evidence_ref" }
        },
        "risk_class": { "enum": ["low", "medium", "high"] },
        "affected_surface": { "type": "string", "minLength": 1 },
        "suggested_next_action": { "type": "string", "minLength": 1 },
        "decision": { "enum": ["accept", "reject", "defer", null] },
        "latest_decision_ref": { "type": ["string", "null"] },
        "action_executed": { "const": false },
        "authority_boundary": { "$ref": "#/definitions/authority_boundary" }
      },
      "additionalProperties": true
    },
    "decision": {
      "type": "object",
      "required": ["schema", "decision_id", "candidate_id", "decided_at", "decision", "status", "decision_ref", "action_executed", "authority_boundary"],
      "properties": {
        "schema": { "const": "agoragentic.harness.improvement-decision.v1" },
        "decision_id": { "type": "string", "minLength": 1 },
        "candidate_id": { "type": "string", "minLength": 1 },
        "decided_at": { "type": "string", "minLength": 1 },
        "decision": { "enum": ["accept", "reject", "defer"] },
        "status": { "enum": ["accepted", "rejected", "deferred"] },
        "decision_ref": { "type": "string", "minLength": 1 },
        "action_executed": { "const": false },
        "authority_boundary": { "$ref": "#/definitions/authority_boundary" }
      },
      "additionalProperties": true
    },
    "evidence_ref": {
      "type": "object",
      "required": ["id", "ref", "present", "hash", "bytes", "raw_content_inlined"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "present": { "type": "boolean" },
        "hash": { "type": ["string", "null"] },
        "bytes": { "type": "integer", "minimum": 0 },
        "raw_content_inlined": { "const": false }
      },
      "additionalProperties": true
    },
    "authority_boundary": {
      "type": "object",
      "required": ["wallet_spend", "marketplace_publication", "x402_settlement", "x402_route_activation", "trust_mutation", "provider_dispatch", "public_execute_mutation", "public_invoke_mutation", "autonomous_self_modification", "source_file_mutation", "git_commit", "pull_request_creation", "hosted_memory_write", "execute_invoke_change"],
      "properties": {
        "wallet_spend": { "const": false },
        "marketplace_publication": { "const": false },
        "x402_settlement": { "const": false },
        "x402_route_activation": { "const": false },
        "trust_mutation": { "const": false },
        "provider_dispatch": { "const": false },
        "public_execute_mutation": { "const": false },
        "public_invoke_mutation": { "const": false },
        "autonomous_self_modification": { "const": false },
        "source_file_mutation": { "const": false },
        "git_commit": { "const": false },
        "pull_request_creation": { "const": false },
        "hosted_memory_write": { "const": false },
        "execute_invoke_change": { "const": false }
      },
      "additionalProperties": true
    }
  }
}
