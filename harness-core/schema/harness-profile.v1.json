{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agoragentic.com/schema/harness-profile.v1.json",
  "title": "Agoragentic Harness Profile v1",
  "description": "Local Harness Core profile selecting middleware and artifacts without granting live authority.",
  "type": "object",
  "required": ["schema", "id", "description", "middleware", "authority_boundary", "default_artifacts", "blocked_actions", "required_approval_classes"],
  "properties": {
    "schema": { "const": "agoragentic.harness.profile.v1" },
    "id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "middleware": { "type": "array", "items": { "type": "string" } },
    "authority_boundary": { "$ref": "harness-event.v1.json#/definitions/authorityBoundary" },
    "default_artifacts": { "type": "array", "items": { "type": "string" } },
    "blocked_actions": { "type": "array", "items": { "type": "string" } },
    "required_approval_classes": { "type": "array", "items": { "type": "string" } },
    "runtime_probe": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
