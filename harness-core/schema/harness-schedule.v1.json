{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agoragentic.com/schema/harness-schedule.v1.json",
  "title": "Agoragentic Harness Schedule v1",
  "description": "Local schedule-intent manifest for Harness Core loops. It computes due state only and grants no daemon, hosted automation, process-control, shell, service-start, SSH, tunnel, wallet, x402, marketplace, hosted provisioning, provider, trust, private ECF, hosted memory, or public execute/invoke authority.",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "updated_at",
    "mode",
    "artifact",
    "scheduling_intent_only",
    "execution_policy",
    "schedules",
    "authority_boundary"
  ],
  "properties": {
    "schema": { "const": "agoragentic.harness.schedule.v1" },
    "generated_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "mode": { "const": "local_no_spend" },
    "artifact": { "const": ".agoragentic/harness-schedule.json" },
    "scheduling_intent_only": { "const": true },
    "execution_policy": {
      "type": "object",
      "required": [
        "automatic_execution",
        "background_service",
        "daemon",
        "hosted_automation",
        "cron_install",
        "task_scheduler_install",
        "systemd_install",
        "process_control",
        "shell_execution",
        "ssh",
        "tunnel",
        "requires_manual_invocation"
      ],
      "properties": {
        "automatic_execution": { "const": false },
        "background_service": { "const": false },
        "daemon": { "const": false },
        "hosted_automation": { "const": false },
        "cron_install": { "const": false },
        "task_scheduler_install": { "const": false },
        "systemd_install": { "const": false },
        "process_control": { "const": false },
        "shell_execution": { "const": false },
        "ssh": { "const": false },
        "tunnel": { "const": false },
        "requires_manual_invocation": { "const": true }
      },
      "additionalProperties": false
    },
    "schedules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "loop",
          "profile",
          "interval",
          "interval_seconds",
          "created_at",
          "updated_at",
          "enabled",
          "mode",
          "scheduling_intent_only",
          "due_check_only",
          "automatic_execution",
          "manual_invocation_required",
          "command_ref",
          "due_policy",
          "no_authority_statement",
          "authority_boundary"
        ],
        "properties": {
          "id": { "type": "string" },
          "loop": { "const": "seller-listing-readiness" },
          "profile": { "const": "seller_listing_readiness" },
          "interval": { "const": "daily" },
          "interval_seconds": { "const": 86400 },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" },
          "enabled": { "const": true },
          "mode": { "const": "local_no_spend" },
          "scheduling_intent_only": { "const": true },
          "due_check_only": { "const": true },
          "automatic_execution": { "const": false },
          "manual_invocation_required": { "const": true },
          "command_ref": { "type": "string" },
          "due_policy": { "type": "string" },
          "no_authority_statement": { "type": "string" },
          "authority_boundary": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    },
    "authority_boundary": {
      "type": "object",
      "required": [
        "wallet_spend",
        "wallet_mutation",
        "deploy_runtime",
        "hosted_runtime_provisioning",
        "marketplace_publication",
        "x402_settlement",
        "x402_route_activation",
        "trust_mutation",
        "ranking_mutation",
        "provider_dispatch",
        "public_execute_mutation",
        "public_invoke_mutation",
        "private_ecf_export",
        "owner_approval_bypass",
        "process_control",
        "arbitrary_shell",
        "automatic_execution",
        "hosted_automation",
        "cron_install",
        "task_scheduler_install",
        "systemd_install",
        "background_service",
        "service_start",
        "ssh",
        "tunnel",
        "hosted_memory_write"
      ],
      "properties": {
        "wallet_spend": { "const": false },
        "wallet_mutation": { "const": false },
        "deploy_runtime": { "const": false },
        "hosted_runtime_provisioning": { "const": false },
        "marketplace_publication": { "const": false },
        "x402_settlement": { "const": false },
        "x402_route_activation": { "const": false },
        "trust_mutation": { "const": false },
        "ranking_mutation": { "const": false },
        "provider_dispatch": { "const": false },
        "public_execute_mutation": { "const": false },
        "public_invoke_mutation": { "const": false },
        "private_ecf_export": { "const": false },
        "owner_approval_bypass": { "const": false },
        "process_control": { "const": false },
        "arbitrary_shell": { "const": false },
        "automatic_execution": { "const": false },
        "hosted_automation": { "const": false },
        "cron_install": { "const": false },
        "task_scheduler_install": { "const": false },
        "systemd_install": { "const": false },
        "background_service": { "const": false },
        "service_start": { "const": false },
        "ssh": { "const": false },
        "tunnel": { "const": false },
        "hosted_memory_write": { "const": false }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
