{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agoragentic.com/schema/worktree-session.v1.json",
  "title": "Agoragentic Harness Worktree Session v1",
  "description": "Local refs-only worktree/branch/PR review metadata for Harness Core coding-agent workflows. It grants no git write, branch creation, push, PR creation, shell execution, framework tool execution, provider dispatch, hosted mutation, hosted memory write, wallet, x402, marketplace, trust, SSH, or tunnel authority.",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "updated_at",
    "mode",
    "artifact",
    "active",
    "refs_only",
    "worktree",
    "latest_harness_run_ref",
    "owner_review_state",
    "artifact_policy",
    "execution_policy",
    "authority_boundary"
  ],
  "properties": {
    "schema": { "const": "agoragentic.harness.worktree-session.v1" },
    "generated_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "mode": { "const": "local_no_spend" },
    "artifact": { "const": ".agoragentic/worktree-session.json" },
    "active": { "type": "boolean" },
    "attached_at": { "type": ["string", "null"] },
    "detached_at": { "type": ["string", "null"] },
    "refs_only": { "const": true },
    "worktree": {
      "type": "object",
      "required": [
        "path",
        "branch",
        "commit_sha",
        "pr_number",
        "pr_url",
        "dirty_state",
        "dirty_state_source",
        "git_status_read"
      ],
      "properties": {
        "path": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "commit_sha": { "type": ["string", "null"] },
        "pr_number": { "type": ["string", "null"] },
        "pr_url": { "type": ["string", "null"] },
        "dirty_state": { "enum": ["clean", "dirty", "unknown"] },
        "dirty_state_source": { "enum": ["user_supplied", "not_supplied"] },
        "git_status_read": { "const": false }
      },
      "additionalProperties": false
    },
    "latest_harness_run_ref": { "type": ["object", "null"], "additionalProperties": true },
    "owner_review_state": { "type": "string" },
    "artifact_policy": {
      "type": "object",
      "required": [
        "refs_only",
        "raw_diff_included",
        "raw_patch_included",
        "raw_git_log_included",
        "raw_tool_output_included",
        "secrets_included"
      ],
      "properties": {
        "refs_only": { "const": true },
        "raw_diff_included": { "const": false },
        "raw_patch_included": { "const": false },
        "raw_git_log_included": { "const": false },
        "raw_tool_output_included": { "const": false },
        "secrets_included": { "const": false }
      },
      "additionalProperties": false
    },
    "execution_policy": {
      "type": "object",
      "required": [
        "git_commands_executed",
        "shell_execution",
        "branch_created",
        "push_performed",
        "pr_created",
        "framework_tool_executed",
        "provider_dispatched",
        "hosted_mutation"
      ],
      "properties": {
        "git_commands_executed": { "const": false },
        "shell_execution": { "const": false },
        "branch_created": { "const": false },
        "push_performed": { "const": false },
        "pr_created": { "const": false },
        "framework_tool_executed": { "const": false },
        "provider_dispatched": { "const": false },
        "hosted_mutation": { "const": false }
      },
      "additionalProperties": false
    },
    "authority_boundary": {
      "type": "object",
      "required": [
        "wallet_spend",
        "wallet_mutation",
        "deploy_runtime",
        "hosted_runtime_provisioning",
        "marketplace_publication",
        "x402_settlement",
        "x402_route_activation",
        "trust_mutation",
        "ranking_mutation",
        "provider_dispatch",
        "public_execute_mutation",
        "public_invoke_mutation",
        "private_ecf_export",
        "owner_approval_bypass",
        "process_control",
        "arbitrary_shell",
        "git_write",
        "git_branch_create",
        "git_push",
        "pr_create",
        "shell_execution",
        "framework_tool_execution",
        "hosted_mutation",
        "hosted_memory_write",
        "service_start",
        "ssh",
        "tunnel"
      ],
      "properties": {
        "wallet_spend": { "const": false },
        "wallet_mutation": { "const": false },
        "deploy_runtime": { "const": false },
        "hosted_runtime_provisioning": { "const": false },
        "marketplace_publication": { "const": false },
        "x402_settlement": { "const": false },
        "x402_route_activation": { "const": false },
        "trust_mutation": { "const": false },
        "ranking_mutation": { "const": false },
        "provider_dispatch": { "const": false },
        "public_execute_mutation": { "const": false },
        "public_invoke_mutation": { "const": false },
        "private_ecf_export": { "const": false },
        "owner_approval_bypass": { "const": false },
        "process_control": { "const": false },
        "arbitrary_shell": { "const": false },
        "git_write": { "const": false },
        "git_branch_create": { "const": false },
        "git_push": { "const": false },
        "pr_create": { "const": false },
        "shell_execution": { "const": false },
        "framework_tool_execution": { "const": false },
        "hosted_mutation": { "const": false },
        "hosted_memory_write": { "const": false },
        "service_start": { "const": false },
        "ssh": { "const": false },
        "tunnel": { "const": false }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
