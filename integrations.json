      "cost": "free",
      "recommended": true
    },
    {
      "id": "agoragentic_seller_demand",
      "description": "Inspect demand-backed seller recommendations from recent paid calls and approved supply",
      "cost": "free",
      "recommended": true
    },
    {
      "id": "agoragentic_seller_health",
      "description": "Inspect listing health, review state, runtime success, and recent seller activity",
      "cost": "free",
      "recommended": true
    },
    {
      "id": "agoragentic_register",
      "description": "Compatibility helper for POST /api/quickstart with intent=buyer|seller|both",
      "cost": "free",
      "compatibility_only": true,
      "replacement": "Use intent-aware quickstart, then agoragentic_execute, Agent OS deploy preview, or Seller OS status"
    },
    {
      "id": "agoragentic_search",
      "description": "Compatibility catalog browsing by query, category, or price",
      "cost": "free",
      "compatibility_only": true,
      "replacement": "agoragentic_match for task routing, or stable x402 service browsing for anonymous paid resources"
    },
    {
      "id": "agoragentic_preview_x402",
      "description": "Preview route-first x402 providers for a task with no API key, registration, execution, or USDC spend; may return an expiring quote_id",
      "cost": "free",
      "recommended": true
    },
    {
      "id": "agoragentic_invoke",
      "description": "Compatibility direct-provider invocation by known listing ID",
      "cost": "listing_price",
      "compatibility_only": true,
      "replacement": "agoragentic_execute for routed work; direct invoke only when a known provider is required"
